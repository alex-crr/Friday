horizontal_move_z = 10
mesh_min = 30,30
mesh_max = 180,180
probe_count = 5, 5

[z_tilt]
z_positions = 
	0, 110
	220, 110
points = 
	5, 110
	180, 110
speed = 80
retries = 10
retry_tolerance = 0.01

[bltouch]
sensor_pin = PA6
control_pin = PA7
x_offset = 25
y_offset = 0
samples = 3
speed = 10
z_offset = 3.000

[safe_z_home]
home_xy_position = 110,110
speed = 50
z_hop = 10
z_hop_speed = 15

[gcode_macro M106]
description = Lockable fan control
rename_existing = M106.1
variable_lock = 0
gcode = 
	{% set S = params.S|default(0)|int %}
	{% set CURLOCK = printer["gcode_macro M106"].lock %}
	{% if 'L' in params %}
	SET_GCODE_VARIABLE MACRO=M106 VARIABLE=lock VALUE={params.L|default(1)|int}
	M106.1 S{S}
	{% else %}
	{% if CURLOCK == 1%}
	RESPOND TYPE=error MSG="FAN LOCK ON SEND M106 L0 TO REMOVE"
	{% else %}
	M106.1 S{S}
	{% endif %}
	{% endif %}

[gcode_macro M190]
rename_existing = M190.1
gcode = 
	{% set S=params.S|default(0)| float %}
	{% set R=params.R|default(0) | float%}
	{% set tolerance = params.tolerance | default(1.0) | float %}
	{% if S != 0.0 %}
	M140 S{S}
	TEMPERATURE_WAIT SENSOR=heater_bed MINIMUM={S|float - tolerance}
	{% elif R != 0.0 %}
	M190.1 S{R}
	{% else %}
	M140 S0
	{% endif %}

[gcode_macro M109]
rename_existing = M109.1
gcode = 
	{% set S=params.S|default(0)| float %}
	{% set R=params.R|default(0) | float%}
	{% set tolerance = params.tolerance | default(1.0) | float %}
	{% if S != 0.0 %}
	M104 S{S}
	TEMPERATURE_WAIT SENSOR=extruder MINIMUM={S|float - tolerance}
	{% elif R != 0.0 %}
	M109.1 S{R}
	{% else %}
	M104 S0
	{% endif %}

[exclude_object]

[gcode_arcs]
resolution = 0.1

[gcode_macro _CLIENT_VARIABLE]
variable_use_custom_pos = True
variable_custom_park_x = 15.0
variable_custom_park_y = 180.0
gcode = 

[gcode_macro END_PRINT]
gcode = 
	
	M104 S0
	M107
	G91
	G1 Z5 X-10 Y-10 E-1 F2400
	G90
	G28 X0 Y0
	G1 Y200
	M84
	M82
	M140 S0

[gcode_macro pid_bed]
description = run the pid configuration
gcode = 
	{% set bed_temp = params.TEMPERATURE|default(60)|float %}
	PID_CALIBRATE HEATER=heater_bed TARGET={bed_temp}
	SAVE_CONFIG

[gcode_macro START_PRINT]
gcode = 
	{% set BED_TEMP=params.BED_TEMP|default(60)|float %}
	{% set EXTRUDER_TEMP=params.EXTRUDER_TEMP|default(205)|float %}
	
	
	G90
	M83
	G28
	
	
	M140 S{BED_TEMP -5}
	M104 S{EXTRUDER_TEMP}
	M140 S{BED_TEMP}
	M109 S{EXTRUDER_TEMP}
	M190 S{BED_TEMP}
	
	
	
	
	
	BED_MESH_PROFILE LOAD=default
	
	
	M104 S{EXTRUDER_TEMP}
	M109 S{EXTRUDER_TEMP}
	
	
	G1 Z5 F3000
	G1 X20 Y5 F1500
	G1 Z0.2 F3000
	G92 E0
	G1 X100 E30 F600
	
	
	G1 Z0.2 F3000
	G1 Y15 F10000

