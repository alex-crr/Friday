[gcode_macro START_PRINT]
gcode = 
	{% set BED_TEMP=params.BED_TEMP|default(60)|float %}
	{% set EXTRUDER_TEMP=params.EXTRUDER_TEMP|default(205)|float %}
	
	
	G90
	M83
	G28
	
	
	M140 S{BED_TEMP -5}
	M104 S{EXTRUDER_TEMP}
	M140 S{BED_TEMP}
	M109 S{EXTRUDER_TEMP}
	M190 S{BED_TEMP}
	
	
	
	
	
	BED_MESH_PROFILE LOAD=default
	
	
	M104 S{EXTRUDER_TEMP}
	M109 S{EXTRUDER_TEMP}
	
	
	G1 Z5 F3000
	G1 X20 Y5 F1500
	G1 Z0.2 F3000
	G92 E0
	G1 X100 E30 F600
	
	
	G1 Z0.2 F3000
	G1 Y15 F10000

