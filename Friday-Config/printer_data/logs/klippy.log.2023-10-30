speed = 100
horizontal_move_z = 10
mesh_min = 30,30
mesh_max = 180,180
probe_count = 5, 5

[z_tilt]
z_positions = 
	0, 110
	220, 110
points = 
	10, 110
	180, 110
speed = 80
retries = 6
retry_tolerance = 0.01

[bltouch]
sensor_pin = PA6
control_pin = PA7
x_offset = 25
y_offset = 10
samples = 3
speed = 2
z_offset = 3.115

[safe_z_home]
home_xy_position = 110,110
speed = 50
z_hop = 10
z_hop_speed = 10

[exclude_object]

[gcode_arcs]
resolution = 0.1

[gcode_macro _CLIENT_VARIABLE]
variable_custom_park_x = 15.0
variable_custom_park_y = 180.0
gcode = 

[gcode_macro pid_bed]
description = run the pid configuration
gcode = 
	{% set bed_temp = params.TEMPERATURE|default(60)|float %}
	PID_CALIBRATE HEATER=heater_bed TARGET={bed_temp}
	SAVE_CONFIG

[gcode_macro START_PRINT]
gcode = 
	{% set BED_TEMP=params.BED_TEMP|default(60)|float %}
	{% set EXTRUDER_TEMP=params.EXTRUDER_TEMP|default(205)|float %}
	
	
	G90
	M83
	G28
	
	
	M190 S{BED_TEMP - 10}
	M104 S{EXTRUDER_TEMP}
	M140 S{BED_TEMP}
	M109 S{EXTRUDER_TEMP}
	M190 S{BED_TEMP}
	
	
	
	
	
	BED_MESH_PROFILE LOAD=default
	
	
	M104 S{EXTRUDER_TEMP}
	M109 S{EXTRUDER_TEMP}
	
	
	G1 Z5 F3000
	G1 X20 Y5 F1500
	G1 Z0.2 F3000
	G92 E0
	G1 X100 E30 F600
	
	
	G1 Z0.2 F3000
	G1 Y15 F10000

